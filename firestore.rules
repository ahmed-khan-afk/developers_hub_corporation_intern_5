rules_version = '2';

// Firestore Security Rules for the Week 5 task.
// Each signed-in user may only read and write their OWN document in
// the `users` collection (keyed by their Firebase Auth uid).
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
